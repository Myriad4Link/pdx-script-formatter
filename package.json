{
  "name": "pdx-script-formatter",
  "displayName": "PDXScript Formatter",
  "publisher": "myriad",
  "description": "Formats Paradox game script files (Stellaris, HOI4, EU4) using prettier-plugin-pdx-script",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:stellaris",
    "onLanguage:hoi4",
    "onLanguage:eu4",
    "onLanguage:paradox"
  ],
  "extensionDependencies": [
    "tboby.cwtools-vscode"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "PDXScript Formatter",
      "properties": {
        "pdxScriptFormatter.logLevel": {
          "type": "string",
          "default": "info",
          "enum": [
            "off",
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "enumDescriptions": [
            "Disable all logging",
            "Log errors only",
            "Log errors and warnings",
            "Log errors, warnings, and informational messages",
            "Log everything including diagnostic details",
            "Log everything including text previews"
          ],
          "description": "Logging level for the PDXScript Formatter output channel (View → Output → PDXScript Formatter)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "prettier-plugin-pdx-script": "^0.1.0-rc.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "prettier": "^3.8.1"
  }
}
